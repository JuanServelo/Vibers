# Conexão com o banco de dados PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO?schema=public
DATABASE_URL="postgresql://postgres:Vibers@2112@localhost:5432/vibers?schema=public"

# Segredo para assinatura dos tokens JWT
# Use uma string longa e aleatória em produção (ex: openssl rand -base64 64)
JWT_SECRET=troque_por_um_segredo_seguro_em_producao

# Porta do servidor HTTP (padrão: 3000)
PORT=3000
